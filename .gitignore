# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/

# ── Next.js build output ──────────────────────────────────────────────────────
.next/
.next-dev/
out/

# ── Environment variables (NEVER commit these) ────────────────────────────────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local

# ── Uploaded user files (large binaries, not part of source code) ─────────────
# Only the ROOT /uploads directory holds user uploads; anchor with a leading
# slash so we don't accidentally ignore code dirs like app/api/uploads/.
# uploads/.gitkeep is committed so the empty folder is tracked.
/uploads/*
!/uploads/.gitkeep

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS / Editor ───────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.vscode/
*.swp
*.swo

# ── Misc ──────────────────────────────────────────────────────────────────────
*.tgz
*.tar.gz
temp.html
